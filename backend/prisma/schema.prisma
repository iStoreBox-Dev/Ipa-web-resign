generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  username     String    @unique
  avatar       String?
  isAdmin      Boolean   @default(false)
  isSubscribed Boolean   @default(false)
  isBanned     Boolean   @default(false)
  storageQuota Int       @default(1073741824)
  usedStorage  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLogin    DateTime?

  certificates Certificate[]
  resignJobs   ResignJob[]
  adminLogs    AdminLog[]    @relation("AdminLogs")
  repositories Repository[]
}

model Certificate {
  id              String    @id @default(cuid())
  userId          String
  filename        String
  certData        String
  provisionData   String?
  certificateType String    @default("p12")
  expiryDate      DateTime?
  bundleId        String?
  teamId          String?
  teamName        String?
  isPublic        Boolean   @default(false)
  usageCount      Int       @default(0)
  createdAt       DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  resignJobs ResignJob[]
}

model Repository {
  id          String    @id @default(cuid())
  url         String    @unique
  name        String
  description String?
  isDefault   Boolean   @default(false)
  lastSynced  DateTime?
  appCount    Int       @default(0)
  createdBy   String?
  createdAt   DateTime  @default(now())

  creator User? @relation(fields: [createdBy], references: [id])
}

model ResignJob {
  id            String    @id @default(cuid())
  userId        String
  ipaFilename   String
  certificateId String?
  accessToken   String?   @unique
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  downloadUrl   String?
  fileSize      Int?
  errorMessage  String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate? @relation(fields: [certificateId], references: [id])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  actionType String
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminLogs", fields: [adminId], references: [id])
}
